[llm]
# "mock" runs fully offline. Use "openai" with OPENAI_API_KEY for model-backed runs.
provider = "mock"
openai_model = "gpt-4.1-mini"
fallback_to_mock = false

[database]
# Docker Compose default:
# postgresql://llm_kg:llm_kg@localhost:54329/llm_kg
url = ""

[embedding]
provider = "mock"
model = "text-embedding-3-small"
dimensions = 1536

[query]
top_k = 5
default_mode = "local"

[ontology]
profile = "generic"

[governance]
enforce_evidence = true
enforce_relation_trace = true

[ocr]
# "none" keeps native pypdf extraction only. "openai" renders failed/timeout PDF pages
# and sends page images to OpenAI Vision OCR when OPENAI_API_KEY is available.
provider = "none"
model = ""
max_pages = 25
timeout_seconds = 30

[validation]
providers = "gemini,xai"
gemini_model = "gemini-2.5-flash"
xai_model = "grok-4.3"
